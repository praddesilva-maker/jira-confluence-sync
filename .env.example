# Copy to .env for non-interactive `forge` CLI use (CI, scripted deploys).
#
# These are the OPERATOR's own Atlassian credentials, used only to authenticate
# the Forge CLI for deploy/install. No client site's credentials are ever
# stored here or anywhere else in this project — see ADR-006.

# The Atlassian account email you run `forge login` with.
FORGE_EMAIL=you@example.com

# A Forge CLI API token for that account (https://go.atlassian.com/forge-cli-api-token).
FORGE_API_TOKEN=
